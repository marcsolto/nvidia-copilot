{
  "name": "nvidia-copilot",
  "displayName": "NVIDIA Copilot",
  "description": "AI-powered coding assistant using NVIDIA's models",
  "version": "0.0.1",
  "publisher": "marcsolto",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "keywords": [
    "nvidia",
    "copilot",
    "ai",
    "llm",
    "rag"
  ],
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "NVIDIA Copilot",
      "properties": {
        "nvidiaCopilot.apiKey": {
          "type": "string",
          "default": "",
          "description": "NVIDIA API Key"
        },
        "nvidiaCopilot.model": {
          "type": "string",
          "default": "meta/llama3-70b-instruct",
          "description": "NVIDIA model for chat completions"
        },
        "nvidiaCopilot.enableInlineSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code suggestions (Ghost Text)"
        }
      }
    },
    "commands": [
      {
        "command": "nvidia.copilot",
        "title": "NVIDIA: Ask about code"
      },
      {
        "command": "nvidia.listModels",
        "title": "NVIDIA: List available models"
      },
      {
        "command": "nvidia.setApiKey",
        "title": "NVIDIA: Set API Key"
      },
      {
        "command": "nvidia.indexWorkspace",
        "title": "NVIDIA: Index Workspace (RAG)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.106.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcsolto/nvidia-copilot.git"
  },
  "license": "MIT"
}